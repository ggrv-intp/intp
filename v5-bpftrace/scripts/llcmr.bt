/*     @misses = count(); */
/* } */

/* hardware:cache-references:1000000 */
/* { */
/*     @refs = count(); */
/* } */

interval:s:1
{
    /* TODO: Compute miss ratio */
    /* TODO: The sampling period cancels out: ratio = misses/refs * 100 */
    /* TODO: Print and reset */
}

END
{
