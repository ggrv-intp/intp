/*
 * nets.bt -- Network Stack Service Time (V5 bpftrace)
 *
 * IntP metric: nets (network stack utilization / service time)
 * Equivalent to: print_netstack_report() in v1-original/intp.stp
 *
 * TX path probes:
 *   kfunc:__dev_queue_xmit         -- entry: packet enters TX queue
 *   tracepoint:net:net_dev_xmit    -- exit: packet transmitted by driver
 *   Service time = net_dev_xmit timestamp - __dev_queue_xmit timestamp
 *
 * RX path probes:
 *   kfunc:__napi_schedule_irqoff   -- entry: NAPI poll scheduled (NIC IRQ)
 *   kfunc:napi_complete_done       -- exit: NAPI poll completed
 *   Service time = napi_complete_done timestamp - __napi_schedule timestamp
 *
 * The original intp.stp uses similar probe points to measure the time
 * packets spend in the kernel networking stack. bpftrace provides
 * equivalent per-packet timestamping via kfunc probes.
 *
 * Formula:
 *   total_service_time_ns = sum of all per-packet service times in interval
 *   utilization = total_service_time_ns / (interval_ns * num_cpus) * 100
 *
 * Usage: sudo bpftrace nets.bt
 */

BEGIN
{
    printf("nets: monitoring network stack service time\n");
}

/* TX path: measure time from queue to transmit */
