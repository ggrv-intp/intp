    /* $start = @rx_start[tid]; */
    /* if ($start > 0) { */
    /*     @rx_total_ns = sum(nsecs - $start); */
    /*     @rx_count = count(); */
    /*     delete(@rx_start[tid]); */
    /* } */
}

interval:s:1
{
